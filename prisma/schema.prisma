generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------------
// Multi-Tenant Branch System
// ----------------------------------------------------------------------------

model Branch {
  id        String   @id @default(cuid())
  code      String   @unique // "HQ", "BG", "GR"
  name      String            // "Malta (HQ)", "Bulgaria", "Greece"
  timezone  String            // "Europe/Malta", "Europe/Sofia", "Europe/Athens"
  currency  String   @default("EUR") // "EUR", "BGN"

  // Relations
  users       User[]
  students    Student[]
  instructors Instructor[]
  events      CourseEvent[]
  payments    Payment[]
  intakes     Intake[]
  activityLogs ActivityLog[]
  tickets     Ticket[]

  createdAt DateTime @default(now())
}

// Staff/Admin Users (Authentication)
enum Role {
  SUPER_ADMIN   // Malta HQ — can access all branches
  BRANCH_ADMIN  // Branch manager — manages own branch
  STAFF         // Branch staff — sees own branch only
  PENDING       // Waiting for approval
}

model User {
  id        String   @id // Clerk user_id
  email     String   @unique
  name      String?
  role      Role     @default(PENDING)

  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id])

  createdAt DateTime @default(now())
}

// ----------------------------------------------------------------------------

// ... existing imports

// ----------------------------------------------------------------------------

// Student Record (Data only, no login)
enum StudentStatus {
  REGISTERED
  DOCS_REQ_SENT
  LECTURE_NOTES_SENT
  PAYMENT_REMINDER_SENT
  PAYMENT_COMPLETED
  COURSE_ONGOING
  EXAM_PHASE
  COURSE_COMPLETED
  CERTIFICATE_APPLIED
  CERTIFICATE_SHIPPED
}

model Student {
  id          String   @id @default(cuid())
  studentNumber String? @unique // YYXXXX format
  
  // Personal Info
  fullName    String
  email       String?
  phone       String?
  address     String?
  nationality String?
  passportNumber String?
  dateOfBirth DateTime?
  
  // Certificate Info
  certificateIssueDate   DateTime?
  certificateExpiryDate  DateTime?
  
  status      StudentStatus @default(REGISTERED)
  
  // Financials
  totalFee    Decimal  @default(0) // Total course fee in EUR
  photoUrl    String?  // Profile Photo URL
  currency    String   @default("EUR")
  paymentDeadline DateTime?
  paymentReminderSent Boolean @default(false)
  
  // Magic Link for Uploads
  uploadToken       String?   @unique
  uploadTokenExpiry DateTime?

  // Feedback Token
  feedbackToken     String?   @unique
  
  // Branch (Multi-tenant)
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id])
  
  // Meta
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  courses     Course[] // Many-to-many relation for enrolled courses
  documents   StudentDocument[]
  documentNotes StudentDocumentNote[]
  remarks     StudentRemark[]
  payments    Payment[]
  feedbacks   Feedback[]
  events      CourseEvent[]
  tickets     Ticket[]
  certificates StudentCertificate[]
  
  intakeId    String?
  intake      Intake?   @relation(fields: [intakeId], references: [id])
  attendances Attendance[]
}

model StudentDocumentNote {
  id             String       @id @default(cuid())
  note           String       @db.Text
  
  studentId      String
  student        Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  documentTypeId String
  documentType   DocumentType @relation(fields: [documentTypeId], references: [id], onDelete: Cascade)
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  
  @@unique([studentId, documentTypeId])
}

model StudentRemark {
  id        String   @id @default(cuid())
  
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  note      String   @db.Text
  date      DateTime @default(now()) // The user wants a date next to the note

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum FeedbackSource {
  LINKEDIN
  WORD_OF_MOUTH
  ADVERTISEMENT
  SOCIAL_MEDIA
  RECOMMENDATION
  OTHER
}

enum RecommendStatus {
  YES
  NO
  MAYBE
}

model Feedback {
  id        String   @id @default(cuid())

  // 1. General Info
  source    FeedbackSource?

  // 2. Ratings (1-5)
  registrationProcess   Int
  practicalStandards    Int   
  courseMaterials       Int
  courseContent         Int
  instructorEffectiveness Int
  overallImpression     Int
  staffFriendliness     Int
  learningEffectiveness Int
  
  // 3. Conclusion
  recommend        RecommendStatus
  courseAttended   String? // Snapshot of course name
  comment          String? @db.Text
  
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
}

// ----------------------------------------------------------------------------

enum InstructorEmploymentType {
  FULL_TIME
  PART_TIME
}

model Instructor {
  id          String   @id @default(cuid())
  fullName    String
  email       String?
  phone       String?
  bio         String?
  specialties String?  // Comma separated or simplified text
  employmentType InstructorEmploymentType @default(FULL_TIME)

  // Branch (Multi-tenant)
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  documents   InstructorDocument[]
  events      CourseEvent[]
}

model InstructorDocument {
  id        String   @id @default(cuid())
  title     String? 
  fileUrl   String
  fileType  String   
  
  createdAt  DateTime  @default(now())

  instructorId   String
  instructor     Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  documentTypeId String?
  documentType   DocumentType? @relation(fields: [documentTypeId], references: [id])
}

// ----------------------------------------------------------------------------

model CourseEvent {
  id        String   @id @default(cuid())
  title     String
  
  startDate DateTime
  endDate   DateTime
  location  String?
  
  color     String?  // For UI coloring

  // Branch (Multi-tenant)
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id])

  // Relations
  instructorId String?
  instructor   Instructor? @relation(fields: [instructorId], references: [id])
  
  courseId     String?
  course       Course?     @relation(fields: [courseId], references: [id])

  intakeId     String?
  intake       Intake?     @relation(fields: [intakeId], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  checklist   EventChecklistItem[]
  eventNotes  CourseEventNote[]
  students    Student[]
  attendances Attendance[]
  certificates StudentCertificate[]
}

model CourseEventNote {
  id            String      @id @default(cuid())
  note          String      @db.Text
  
  courseEventId String
  courseEvent   CourseEvent @relation(fields: [courseEventId], references: [id], onDelete: Cascade)

  createdBy     String // Name of the user who created it
  createdAt     DateTime    @default(now())
}

model EventChecklistItem {
  id            String      @id @default(cuid())
  label         String
  phase         String      @default("General")
  isCompleted   Boolean     @default(false)
  
  courseEventId String
  courseEvent   CourseEvent @relation(fields: [courseEventId], references: [id], onDelete: Cascade)

  completedAt   DateTime?
  completedBy   String? // Store user name
  note          String?
  order         Int       @default(0)
}

// ----------------------------------------------------------------------------

// Payment / Ledger
enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CREDIT_CARD
}

model Payment {
  id          String        @id @default(cuid())
  amount      Decimal
  currency    String        @default("EUR") // EUR, BGN
  date        DateTime      @default(now())
  method      PaymentMethod @default(CASH)
  note        String?       // e.g. "Installment 1", "Registration Fee"
  
  // Branch (Multi-tenant)
  branchId    String?
  branch      Branch?       @relation(fields: [branchId], references: [id])
  
  // Relations
  studentId   String
  student     Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime      @default(now())
}

// ----------------------------------------------------------------------------

// Documents
enum DocCategory {
  OFFICE       // Internal docs
  STUDENT      // Personal docs
  CERTIFICATE  // New Category 1
  MEDICAL      // New Category 2
  INSTRUCTOR   // Instructor docs
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

model DocumentType {
  id          String      @id @default(cuid())
  title       String
  titleTr     String?     // Optional Turkish title
  description String?
  descriptionTr String?   // Optional Turkish description
  category    DocCategory @default(STUDENT)
  isRequired  Boolean     @default(true)
  exampleUrl  String?     // URL to an example document or template
  
  documents   StudentDocument[]
  instructorDocuments InstructorDocument[]
  courseRequirements CourseDocument[]
  studentNotes StudentDocumentNote[]
}

model StudentDocument {
  id        String   @id @default(cuid())
  title     String?  // Optional override or custom name
  fileUrl   String
  fileType  String   // pdf, img, etc.
  
  status     DocumentStatus @default(APPROVED)
  
  expiryDate DateTime?
  createdAt  DateTime  @default(now())

  // Relations
  studentId      String
  student        Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  documentTypeId String
  documentType   DocumentType @relation(fields: [documentTypeId], references: [id])
}

model Course {
  id        String   @id @default(cuid())
  title     String   @unique
  titleTr   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  checklistTemplate Json? // Array of { phase: string, items: string[] }
  
  events    CourseEvent[]
  requiredDocuments CourseDocument[]
  students  Student[]
}

model CourseDocument {
  id             String       @id @default(cuid())
  
  courseId       String
  course         Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  documentTypeId String
  documentType   DocumentType @relation(fields: [documentTypeId], references: [id], onDelete: Cascade)
  
  isRequired     Boolean      @default(true)
  
  createdAt      DateTime     @default(now())
  
  @@unique([courseId, documentTypeId])
}

model Intake {
  id        String   @id @default(cuid())
  name      String   // e.g. "March 2025"
  startDate DateTime?
  status    String   @default("ACTIVE") // ACTIVE, ARCHIVED
  
  // Branch (Multi-tenant)
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id])
  
  students  Student[]
  events    CourseEvent[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActivityLog {
  id        String   @id @default(cuid())
  
  action    String   // LOGIN, UPLOAD, VIEW, DELETE, CREATE
  title     String   // "Uploaded document.pdf" or "Viewed Dashboard"
  description String? @db.Text // Optional details
  
  userId    String?  // If authenticated user
  userEmail String?  // Store email for easy reading
  
  // Branch (Multi-tenant)
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id])
  
  ipAddress String?
  userAgent String?
  
  metadata  Json?    // Flexible storage for extra data (fileId, studentId etc)
  createdAt DateTime @default(now())
}

// ----------------------------------------------------------------------------
// Ticketing / Inbox System
// ----------------------------------------------------------------------------

enum TicketStatus {
  OPEN
  CLOSED
}

model Ticket {
  id          String   @id @default(cuid())
  subject     String   @db.Text
  contactEmail  String?
  status      TicketStatus @default(OPEN)
  
  studentId   String?
  student     Student?  @relation(fields: [studentId], references: [id])
  
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messages    TicketMessage[]
}

model TicketMessage {
  id          String   @id @default(cuid())
  ticketId    String
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  
  body        String   @db.Text
  fromEmail   String
  toEmail     String
  
  isFromStudent Boolean @default(true) // Identify direction of email
  
  attachments Json? // Keep simple list of URLs
  messageId   String? // Store inbound Message-Id to track threads properly
  
  createdAt   DateTime @default(now())
}

// ----------------------------------------------------------------------------
// Attendance Tracking Matrix
// ----------------------------------------------------------------------------

model Attendance {
  id          String   @id @default(cuid())
  
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  eventId     String
  event       CourseEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  date        DateTime // The specific date of attendance
  isPresent   Boolean  @default(true) // Maps to "X" in the UI
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([studentId, eventId, date]) // A student can only have 1 attendance record per event day
}

// ----------------------------------------------------------------------------
// Generated Certificates (Track TM unique rules safely)
// ----------------------------------------------------------------------------

model StudentCertificate {
  id              String   @id @default(cuid())
  studentId       String
  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  courseEventId   String?  // The specific run of the STCW course
  courseEvent     CourseEvent? @relation(fields: [courseEventId], references: [id])
  
  certificateType String   // e.g. "stcw-basic-safety"
  certificateNo   String?  // e.g. "2604-01"
  issueDate       DateTime?
  expiryDate      DateTime?
  
  createdAt       DateTime @default(now())
  
  @@unique([studentId, courseEventId, certificateType]) 
}
